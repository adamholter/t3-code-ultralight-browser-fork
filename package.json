{
  "name": "t3-code-ultralight-browser-fork",
  "version": "0.26.0",
  "description": "An ultralight browser bridge, headless client, and embeddable chat UI for local Codex.",
  "license": "MIT",
  "private": false,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/adamholter/t3-code-ultralight-browser-fork.git"
  },
  "homepage": "https://github.com/adamholter/t3-code-ultralight-browser-fork#readme",
  "bugs": "https://github.com/adamholter/t3-code-ultralight-browser-fork/issues",
  "keywords": [
    "codex",
    "openai",
    "local",
    "chat",
    "react",
    "web-component",
    "websocket",
    "agent-ui"
  ],
  "sideEffects": [
    "./dist-lib/element-auto.js"
  ],
  "files": [
    "bin",
    "dist",
    "dist-lib",
    "docs",
    "examples",
    "integration.json",
    "llms.txt",
    "CHANGELOG.md",
    "LICENSE",
    "NOTICE",
    "README.md"
  ],
  "bin": {
    "t3-code-ultralight": "./bin/cli.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist-lib/client.d.ts",
      "import": "./dist-lib/client.js"
    },
    "./client": {
      "types": "./dist-lib/client.d.ts",
      "import": "./dist-lib/client.js"
    },
    "./react": {
      "types": "./dist-lib/react.d.ts",
      "import": "./dist-lib/react.js"
    },
    "./element": {
      "types": "./dist-lib/element.d.ts",
      "import": "./dist-lib/element.js"
    },
    "./element/auto": {
      "types": "./dist-lib/element-auto.d.ts",
      "import": "./dist-lib/element-auto.js"
    },
    "./embed-events": {
      "types": "./dist-lib/embed-events.d.ts",
      "import": "./dist-lib/embed-events.js"
    },
    "./server": {
      "types": "./dist-lib/server.d.ts",
      "import": "./dist-lib/server.js"
    },
    "./doctor": {
      "types": "./dist-lib/doctor.d.ts",
      "import": "./dist-lib/doctor.js"
    },
    "./requests": {
      "types": "./dist-lib/requests.d.ts",
      "import": "./dist-lib/requests.js"
    },
    "./types": {
      "types": "./dist-lib/types.d.ts",
      "import": "./dist-lib/types.js"
    }
  },
  "scripts": {
    "dev": "concurrently -k -n bridge,web -c blue,green \"tsx watch server/index.ts\" \"vite\"",
    "build": "npm run typecheck && npm run build:app && npm run build:lib",
    "build:app": "vite build",
    "build:lib": "tsup",
    "typecheck": "tsc --noEmit",
    "start": "NODE_ENV=production tsx server/index.ts",
    "test": "vitest run",
    "check": "npm run test && npm run build && npm run check:artifact",
    "check:artifact": "node scripts/check-artifact.mjs",
    "package:release": "node scripts/package-release.mjs",
    "prepare": "npm run build"
  },
  "dependencies": {
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.5",
    "@types/node": "^24.8.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.0.4",
    "concurrently": "^9.2.1",
    "lucide-react": "^0.545.0",
    "preact": "^10.29.7",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.1.9",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "overrides": {
    "esbuild": "0.28.1"
  }
}
