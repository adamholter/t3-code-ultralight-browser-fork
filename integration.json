{
  "schemaVersion": 1,
  "name": "t3-code-ultralight-browser-fork",
  "version": "0.47.0",
  "repository": "https://github.com/adamholter/t3-code-ultralight-browser-fork",
  "purpose": "Let a local web, canvas, voice, or custom interface talk to the user's authenticated local Codex.",
  "requirements": {
    "node": ">=22",
    "codex": "Installed and authenticated Codex CLI"
  },
  "release": {
    "specifier": "https://github.com/adamholter/t3-code-ultralight-browser-fork/releases/latest/download/t3-code-ultralight-browser-fork.tgz?v=0.47.0",
    "doctorCommand": "npx --yes 'https://github.com/adamholter/t3-code-ultralight-browser-fork/releases/latest/download/t3-code-ultralight-browser-fork.tgz?v=0.47.0' doctor --json",
    "startCommand": "npx --yes 'https://github.com/adamholter/t3-code-ultralight-browser-fork/releases/latest/download/t3-code-ultralight-browser-fork.tgz?v=0.47.0' start --json",
    "setupCommands": {
      "iframe": "npx --yes 'https://github.com/adamholter/t3-code-ultralight-browser-fork/releases/latest/download/t3-code-ultralight-browser-fork.tgz?v=0.47.0' setup --mode iframe --port auto --json",
      "react": "npx --yes 'https://github.com/adamholter/t3-code-ultralight-browser-fork/releases/latest/download/t3-code-ultralight-browser-fork.tgz?v=0.47.0' setup --mode react --port auto --json",
      "element": "npx --yes 'https://github.com/adamholter/t3-code-ultralight-browser-fork/releases/latest/download/t3-code-ultralight-browser-fork.tgz?v=0.47.0' setup --mode element --port auto --json",
      "elementHosted": "npx --yes 'https://github.com/adamholter/t3-code-ultralight-browser-fork/releases/latest/download/t3-code-ultralight-browser-fork.tgz?v=0.47.0' setup --mode element --delivery hosted --port auto --json",
      "custom": "npx --yes 'https://github.com/adamholter/t3-code-ultralight-browser-fork/releases/latest/download/t3-code-ultralight-browser-fork.tgz?v=0.47.0' setup --mode custom --port auto --json",
      "customHosted": "npx --yes 'https://github.com/adamholter/t3-code-ultralight-browser-fork/releases/latest/download/t3-code-ultralight-browser-fork.tgz?v=0.47.0' setup --mode custom --delivery hosted --port auto --json"
    },
    "verification": {
      "workflow": ".github/workflows/release.yml",
      "trigger": "published GitHub release",
      "cleanCheckout": true,
      "standardChecks": true,
      "productionAudit": true,
      "npmPublishDryRun": true,
      "githubProvenanceAttestation": true,
      "verifiedAssetReplacement": true,
      "optionalNpmPublish": "enabled only when NPM_PUBLISH_ENABLED is true and the repository NPM_TOKEN secret is configured"
    }
  },
  "bridge": {
    "bind": "127.0.0.1",
    "port": 4174,
    "httpUrl": "http://127.0.0.1:4174",
    "websocketUrl": "ws://127.0.0.1:4174/ws",
    "statusPath": "/api/status",
    "integrationPath": "/api/integration",
    "commands": {
      "status": "t3-code-ultralight status --json",
      "stop": "t3-code-ultralight stop --json",
      "foreground": "t3-code-ultralight serve"
    },
    "workspace": {
      "default": "directory where setup, start, or serve is invoked",
      "overrideFlag": "--cwd <absolute or relative project path>",
      "reusePolicy": "exact normalized workspace fingerprint",
      "browserPathDisclosure": false
    },
    "automaticPort": {
      "flag": "--port auto",
      "preferredPort": 4174,
      "fallbackRange": [42000, 59999],
      "deterministicBy": "normalized workspace",
      "compatibleBridgeReuse": true,
      "incompatibleListenerPreserved": true,
      "receiptReturnsResolvedPort": true
    }
  },
  "modes": {
    "completeChat": {
      "useWhen": "The host wants a complete isolated chat UI.",
      "recommended": true,
      "iframeUrl": "http://127.0.0.1:4174/?embed=1",
      "webComponentModule": "http://127.0.0.1:4174/codex-chat.js",
      "controllerModule": "http://127.0.0.1:4174/codex-embed.js",
      "hostCommands": [
        "send",
        "newThread",
        "stop"
      ],
      "hostCommandResponses": "acknowledgements and thread or turn IDs only; never prompt or response text",
      "hostCommandOriginPolicy": "exact parent window plus the bridge's effective browser-origin allowlist",
      "elementDeliveries": ["package", "hosted"],
      "packageExports": ["t3-code-ultralight-browser-fork/element/auto", "t3-code-ultralight-browser-fork/react"],
      "reactCompatibility": {
        "peerRange": "^18.0.0 || ^19.0.0",
        "browserVerified": ["18.3.1", "19.2.0"],
        "strictModeVerified": true,
        "ssrVerified": true,
        "hydrationVerified": true,
        "controllerRefVerified": true,
        "remountVerified": true,
        "clientDirective": true,
        "nextAppRouterVerified": ["16.2.10"],
        "serverComponentImportVerified": true,
        "productionBuildVerified": true
      },
      "webComponentCompatibility": {
        "browserVerified": {
          "vue": ["3.5.39"],
          "svelte": ["5.56.4"]
        },
        "packageInstallVerified": true,
        "singleMountInitializationVerified": true,
        "preReadyControllerVerified": true,
        "remountVerified": true
      }
    },
    "customUi": {
      "useWhen": "The host already owns a canvas, voice, spatial, game, or bespoke interface.",
      "assistantModule": "http://127.0.0.1:4174/codex-assistant.js",
      "browserModule": "http://127.0.0.1:4174/codex-client.js",
      "requestModule": "http://127.0.0.1:4174/codex-requests.js",
      "deliveries": ["package", "hosted"],
      "packageExports": ["t3-code-ultralight-browser-fork/assistant", "t3-code-ultralight-browser-fork/client", "t3-code-ultralight-browser-fork/requests"],
      "primaryApi": "createCodexAssistant",
      "sessionApi": "createCodexSession",
      "requestApi": "attachCodexRequestHandlers",
      "sessionRequestApi": "attachCodexSessionRequestHandlers",
      "sharedClientSupported": true,
      "typedClientEvents": true,
      "unknownEventEscapeHatch": true,
      "defaultBridgeConfigurationRequired": false,
      "requestAdapterOwnedByAssistant": true,
      "missingRequestHandlersFailClosed": true,
      "dispose": "await assistant.close()"
    },
    "attachedServer": {
      "useWhen": "An existing Node HTTP server should own the bridge lifecycle.",
      "packageExport": "t3-code-ultralight-browser-fork/server",
      "primaryApi": "attachCodexBridge",
      "browserUrlRequired": true,
      "exactPathIsolation": true,
      "hostWebSocketCoexistenceVerified": true,
      "idempotentStop": true,
      "listenersReleasedOnStop": true,
      "hostServerPreservedOnStop": true,
      "restartAfterStop": false,
      "pendingRequestsRejectedBeforeProcessStop": true,
      "browserSocketCloseTimeoutMsDefault": 1000,
      "nonCooperativeSocketTerminationVerified": true,
      "publicWsTypeDependency": false
    }
  },
  "security": {
    "loopbackOnly": true,
    "browserCredentials": false,
    "wildcardOrigins": false,
    "exactOriginAllowlist": true,
    "exactOriginReuse": true,
    "exactWorkspaceReuse": true,
    "originSupersetReuseRequiresOptIn": true,
    "strictCliArguments": true,
    "approvalOwnership": true,
    "threadNotificationIsolation": true,
    "attachedWebSocketPathIsolation": true,
    "attachedLifecycleCleanup": true,
    "boundedAttachedSocketShutdown": true,
    "deterministicAutoPortSelection": true,
    "safeMissingRequestHandlers": true,
    "localPathDisclosure": false,
    "pathFreeSetupRecipes": true,
    "upgradeSafeCaching": true,
    "embedCompatibleCsp": true,
    "runtimeAwareIntegrationContract": true,
    "zeroInstallHostedRecipes": true,
    "packedConsumerCiGate": true,
    "httpsNonLoopbackOriginVerified": true,
    "explicitOpaqueFileOriginVerified": true,
    "responseMarkdownRawHtml": false,
    "attestedReleaseArtifacts": true
  },
  "acceptance": [
    "doctor reports ok true",
    "bridge status is ready",
    "one real local Codex turn streams through the final user-facing UI",
    "stop and approval paths remain operable",
    "no Codex credential or token is copied into browser code",
    "an unlisted non-loopback browser origin is rejected",
    "a fresh packed consumer compiles and imports every declared package export",
    "an allowed HTTPS non-loopback host streams while an unlisted sibling origin fails HTTP modules and WebSocket upgrades",
    "a trusted file origin streams only with the explicit null allowlist and matching CORS",
    "a complete-chat host can send before iframe readiness, receive only IDs, stop, and start a clean thread without iframe DOM access",
    "complete-chat commands from an unlisted or spoofed parent origin are ignored without acknowledgement",
    "setup from a fresh project directory makes that directory the bridge default without embedding its path in browser status",
    "a bridge started for one workspace is not silently reused as another project's default",
    "setup-generated browser code inherits the bridge workspace without embedding an absolute local path",
    "the exact packed React export server-renders and streams in clean React 18 and React 19 hosts",
    "the exact packed React export builds in Next.js 16 App Router, imports directly from a Server Component, and streams through the production host",
    "the exact packed Web Component streams in clean Vue 3 and Svelte 5 hosts with one mount initialization and pre-ready controller calls",
    "the exact packed attached-server export streams on its custom path without touching the host's HTTP or WebSocket routes",
    "attached shutdown rejects pending owned requests before process exit and terminates non-cooperative browser sockets within its configured bound",
    "automatic setup coexists with another project's default bridge, repeats on the same deterministic port, and returns exact runtime URLs",
    "the exact generated hosted assistant recipe uses one import, streams a stateful follow-up, cancels an active turn, and disposes its scoped fail-closed request adapter",
    "published release archives are rebuilt from the tag, checked, audited, npm-dry-run verified, provenance-attested, and replaced by GitHub Actions",
    "the standalone browser app remains within 110000 decoded JavaScript and CSS bytes"
  ],
  "performance": {
    "browserAppBudgetBytes": 110000,
    "externalMarkdownRuntimeDependencies": 0,
    "fontRequests": 0
  },
  "documentation": {
    "readme": "README.md",
    "agentGuide": "docs/AGENT_INTEGRATION.md",
    "integrationGuide": "docs/INTEGRATION.md"
  }
}
